#!/bin/bash
# postinst — Vibing Linux post-installation script
# Called after .deb files are unpacked
set -e

APP_DIR="/opt/vibing-linux"
VENV_DIR="${APP_DIR}/venv"
TORCH_VERSION="2.11.0"

echo "═══ Vibing Linux: Setting up Python environment ═══"

# ── 1. Create virtual environment with system site-packages ──────────────────
#    System site-packages needed for PyGObject (python3-gi)
if [ ! -d "$VENV_DIR" ]; then
    echo "→ Creating Python virtual environment..."
    python3 -m venv --system-site-packages "$VENV_DIR"
fi

# ── 2. Install Python dependencies ──────────────────────────────────────────
echo "→ Installing Python dependencies (this may take a few minutes)..."
"$VENV_DIR/bin/pip" install --upgrade pip --quiet
"$VENV_DIR/bin/pip" install "$APP_DIR" --quiet

# ── 3. Detect GPU and install appropriate PyTorch build ─────────────────────
install_torch_cpu() {
    echo "→ Installing CPU-only PyTorch..."
    "$VENV_DIR/bin/pip" install "torch==${TORCH_VERSION}+cpu" \
        --extra-index-url https://download.pytorch.org/whl/cpu \
        --force-reinstall --no-deps --quiet
}

install_torch_cuda() {
    local cu_tag="$1"
    echo "→ Installing PyTorch with CUDA (${cu_tag})..."
    "$VENV_DIR/bin/pip" install "torch==${TORCH_VERSION}+${cu_tag}" \
        --extra-index-url "https://download.pytorch.org/whl/${cu_tag}" \
        --force-reinstall --no-deps --quiet

    echo "→ Installing NVIDIA CUDA runtime libraries..."
    "$VENV_DIR/bin/pip" install nvidia-cublas-cu12 nvidia-cudnn-cu12 --quiet
}

if command -v nvidia-smi &>/dev/null; then
    DRIVER_CUDA=$(nvidia-smi 2>/dev/null | grep -oP 'CUDA Version: \K[0-9]+\.[0-9]+' || true)
    if [ -n "$DRIVER_CUDA" ]; then
        CU_TAG="cu$(echo "$DRIVER_CUDA" | tr -d '.')"
        install_torch_cuda "$CU_TAG"
    else
        echo "→ nvidia-smi found but could not detect CUDA version."
        install_torch_cpu
    fi
else
    install_torch_cpu
fi

# ── 4. Update desktop database and icon cache ───────────────────────────────
if command -v update-desktop-database &>/dev/null; then
    update-desktop-database /usr/share/applications/ 2>/dev/null || true
fi

if command -v gtk-update-icon-cache &>/dev/null; then
    gtk-update-icon-cache -f /usr/share/icons/hicolor/ 2>/dev/null || true
fi

# ── 5. Verify ────────────────────────────────────────────────────────────────
echo ""
echo "═══ Verifying installation ═══"
"$VENV_DIR/bin/python" -c "
import torch
cuda = torch.cuda.is_available()
print(f'  Python:  OK')
print(f'  PyTorch: {torch.__version__}')
print(f'  CUDA:    {\"yes — \" + torch.cuda.get_device_name(0) if cuda else \"no (CPU mode)\"}')
" 2>/dev/null || echo "  Warning: Could not verify PyTorch installation."

echo ""
echo "═══ Vibing Linux installed successfully! ═══"
echo ""
echo "  Run 'vibing-linux' to start."
echo "  On first launch, required AI models will be downloaded automatically."
echo ""

exit 0
